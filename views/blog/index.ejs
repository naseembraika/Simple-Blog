<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include('./partials/head.ejs') %>
    </head>
    <body>
        <!-- Navigation-->
        <nav class="navbar navbar-expand-lg navbar-light" id="mainNav">
            <%- include('./partials/navigation.ejs') %>
        </nav>
        <!-- Page Header-->
        <header class="masthead" style="background-image: url('/<%= coverPath %>')">
            <%- include('./partials/header.ejs') %>
        </header>
        <!-- Main Content-->
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5 justify-content-center">
                <div class="col-md-10 col-lg-8 col-xl-7">
                    <% articles.forEach(article => { %>
                        <!-- Post preview-->
                        <div class="post-preview">
                            <a href="/article/<%= article.slug %>">
                                <h2 class="post-title"><%= article.title %></h2>
                                <h3 class="post-subtitle"><%= article.description %></h3>
                            </a>
                            <p class="post-meta">
                                Posted by
                                <a href="/author/<%= article.author._id %>"><%= article.author.name %></a>
                                on
                                <%= article.createdAt.toLocaleDateString('default', { month: 'long' }) %>
                                <%= article.createdAt.getDate() %>,
                                <%= article.createdAt.getFullYear() %>
                            </p>
                        </div>
                        <!-- Divider-->
                        <hr class="my-4" />
                    <% }) %>
                    <div class="d-flex justify-content-end mb-4"><a class="btn btn-primary text-uppercase" href="#!">Older Posts →</a></div>
                </div>
            </div>
        </div>
        <!-- Footer-->
        <footer class="border-top">
            <%- include('./partials/footer.ejs') %>
        </footer>
        <!-- Bootstrap core JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <!-- Core theme JS-->
        <script src="/blog/js/scripts.js"></script>
    </body>
</html>
