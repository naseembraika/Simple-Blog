<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <title>Markdown Blog</title>
</head>
<body>
    <div class="container">
        <% if(Object.keys(articleData).length == 0) { %>
            <div>Not Found</div>
        <% } else { %>
            <h1 class="mb-1"><%= articleData.title %></h1>
            <div class="text-muted mb-2">
                <%= articleData.createdAt.toLocaleDateString() %>
            </div>
            <a href="/dashboard" class="btn btn-secondary">All Articles</a>
            <a href="/dashboard/articles/edit/<%= articleData._id %>" class="btn btn-info">Edit</a>
    
            <div>
                <%- articleData.markdown %>
            </div>
        <% } %>
    </div>
</body>
</html>