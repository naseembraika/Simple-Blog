<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <title>Markdown Blog</title>
</head>

<body>
    <div class="container">
        <h1 class="mb-4">Update Profile</h1>
        <% if (locals.message) { %>
            <h4 class="row justify-content-center" style="color:red"><%= message %></h4>
        <% } %>

        <form action="/dashboard/admin/update/<%= author._id%>?_method=PUT" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" name="name" id="name" class="form-control" value="<%= author.name %>">
            </div>
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" name="username" id="username" class="form-control" value="<%= author.username %>">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" name="email" id="email" class="form-control" value="<%= author.email %>">
            </div>
            <div class="form-group">
                <label for="bio">Bio</label>
                <input type="text" name="bio" id="bio" class="form-control" value="<%= author.bio %>">
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea name="description" id="description" rows="10" class="form-control"><%= author.description %></textarea>
            </div>
            <div class="form-group">
                <label for="cover_profile">Cover</label>
                <input type="file" name="cover_profile" id="cover_profile" class="form-control">
            </div>
            <a href="/dashboard" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Update</button>
        </form>
    </div>
</body>

</html>